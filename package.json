{
  "name": "techcup-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:back": "cd ../Tech-Up-Futbol-BackEnd && git checkout develop && git pull && mvnw.cmd spring-boot:run -DskipTests",
